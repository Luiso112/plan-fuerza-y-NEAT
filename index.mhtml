@charset "utf-8";

@import url("https://fonts.googleapis.com/css2?family=3DInter:wght@300;400;=
500;600;700;800&family=3DJetBrains+Mono:wght@400;700&display=3Dswap");

body { font-family: Inter, sans-serif; transition: background-color 0.3s, c=
olor 0.3s; }

.font-mono-custom { font-family: "JetBrains Mono", monospace; }

@keyframes pulseRing {=20
  0% { transform: scale(0.95); opacity: 0.5; }
  50% { transform: scale(1.05); opacity: 0.8; }
  100% { transform: scale(0.95); opacity: 0.5; }
}

.ring-active { animation: 3s ease-in-out 0s infinite normal none running pu=
lseRing; }

@keyframes breatheIn {=20
  0% { transform: scale(1); background-color: rgb(167, 243, 208); }
  100% { transform: scale(1.8); background-color: rgb(52, 211, 153); }
}

@keyframes breatheHold {=20
  0% { transform: scale(1.8); background-color: rgb(52, 211, 153); }
  100% { transform: scale(1.8); background-color: rgb(96, 165, 250); }
}

@keyframes breatheOut {=20
  0% { transform: scale(1.8); background-color: rgb(96, 165, 250); }
  100% { transform: scale(1); background-color: rgb(167, 243, 208); }
}

.anim-inhale { animation: 4s cubic-bezier(0.4, 0, 0.2, 1) 0s 1 normal forwa=
rds running breatheIn; }

.anim-hold { animation: 7s linear 0s 1 normal forwards running breatheHold;=
 }

.anim-exhale { animation: 8s cubic-bezier(0.4, 0, 0.2, 1) 0s 1 normal forwa=
rds running breatheOut; }

@media print {
  body { background-color: white !important; color: black !important; }
  .no-print { display: none !important; }
  .print-card { break-inside: avoid; border: 1px solid rgb(226, 232, 240) !=
important; background: white !important; color: black !important; box-shado=
w: none !important; }
  .print-break-before { break-before: page; }
  .text-teal-400, .text-indigo-400, .text-amber-500 { color: rgb(15, 118, 1=
10) !important; }
  .print-full-grid { grid-template-columns: 1fr !important; }
}
